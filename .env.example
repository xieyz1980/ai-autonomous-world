# AI Autonomous World - Environment Configuration
# AI自主世界 - 环境配置

# API Keys（必需）
OPENAI_API_KEY=your-openai-api-key-here

# API Keys（可选）
ANTHROPIC_API_KEY=your-anthropic-api-key-here
COZE_API_KEY=your-coze-api-key-here

# 系统配置
AI_WORLD_HOST=0.0.0.0
AI_WORLD_PORT=8080
AI_WORLD_LOG_LEVEL=INFO

# 节点配置
COORDINATOR_NODE_ID=coordinator-001
DEFAULT_WORKERS=3

# 安全配置
MAX_WORKERS=10
ENABLE_AUTO_SCALING=false
TASK_TIMEOUT=300

# 实验配置（谨慎修改）
ENABLE_AUTONOMOUS_GOALS=true
GOAL_GENERATION_INTERVAL=3600
CONSENSUS_THRESHOLD=0.5
